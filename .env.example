# Copy this file to .env and fill in the values.
# All settings are optional; the defaults are shown below.

# --- Server ---
HOST=0.0.0.0
PORT=8080

# --- Database ---
DATABASE_URL=sqlite:///./ollama_queue.db

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT=300          # seconds to wait for an Ollama response

# --- Worker ---
WORKER_POLL_INTERVAL=2.0    # seconds between queue polls
WORKER_MAX_RETRIES=3        # how many times to retry a failed job
WORKER_RETRY_DELAY=5.0      # seconds between retries

# --- Wake-on-LAN (leave blank to disable) ---
WOL_MAC_ADDRESS=            # e.g. AA:BB:CC:DD:EE:FF
WOL_BROADCAST=255.255.255.255
WOL_PORT=9
